rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection - users can only read/write their own data
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Journey progress - users can only read/write their own progress
    match /journeyProgress/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Course progress - users can only read/write their own progress
    match /courseProgress/{userId} {
      allow read, write: if isOwner(userId);
    }

    // User badges - users can only read/write their own badges
    // Document ID format: {userId}_{badgeId}
    match /userBadges/{docId} {
      allow read: if isAuthenticated() && docId.split('_')[0] == request.auth.uid;
      allow write: if isAuthenticated() && docId.split('_')[0] == request.auth.uid;
    }

    // Arcade records - users can only read/write their own records
    // Document ID format: {userId}_{gameId}
    match /arcadeRecords/{docId} {
      allow read: if isAuthenticated() && docId.split('_')[0] == request.auth.uid;
      allow write: if isAuthenticated() && docId.split('_')[0] == request.auth.uid;
    }

    // Spirit guides - public read, authenticated write
    match /spiritGuides/{guideId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // WW2 Hosts - public read, authenticated write
    match /ww2Hosts/{hostId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Courses - public read, authenticated write
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Units - public read, authenticated write
    match /units/{unitId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Lessons - public read, authenticated write
    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Lesson content - public read, authenticated write
    match /lessonContent/{contentId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // App settings (era order, onboarding, module assets, etc.)
    match /appSettings/{settingId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
