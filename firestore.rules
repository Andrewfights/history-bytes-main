rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Development mode: allow all reads and writes
    // TODO: Restrict to authenticated users in production

    // Users collection
    match /users/{userId} {
      allow read, write: if true;
    }

    // Journey progress
    match /journeyProgress/{userId} {
      allow read, write: if true;
    }

    // Course progress
    match /courseProgress/{userId} {
      allow read, write: if true;
    }

    // User badges
    match /userBadges/{docId} {
      allow read, write: if true;
    }

    // Arcade records
    match /arcadeRecords/{docId} {
      allow read, write: if true;
    }

    // Spirit guides
    match /spiritGuides/{guideId} {
      allow read, write: if true;
    }

    // Courses
    match /courses/{courseId} {
      allow read, write: if true;
    }

    // Units
    match /units/{unitId} {
      allow read, write: if true;
    }

    // Lessons
    match /lessons/{lessonId} {
      allow read, write: if true;
    }

    // Lesson content
    match /lessonContent/{contentId} {
      allow read, write: if true;
    }
  }
}
